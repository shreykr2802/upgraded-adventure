# ─────────────────────────────────────────────
# LLM Gateway — fill in real values
# ─────────────────────────────────────────────

# Your org's OpenAI-compatible gateway base URL (no trailing slash)
# e.g. https://llm-gateway.internal.baxter.com/v1
LLM_GATEWAY_URL=https://your-gateway.internal/v1

# Single API key for all models
LLM_GATEWAY_KEY=your-api-key-here

# ─────────────────────────────────────────────
# Model identifiers
# Confirm exact strings with your gateway admin
# ─────────────────────────────────────────────
MODEL_SONNET=claude-sonnet-4-6
MODEL_HAIKU=claude-haiku-3-5
MODEL_CODE_EMBED=baai/llm-embedder
MODEL_DOC_EMBED=amazon.titan-embed-text-v2
MODEL_RERANKER=baai/bge-reranker-large

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CHROMA_PATH=./chroma_storage
